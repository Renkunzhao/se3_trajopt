<go2_flip>
    <description>Go2 frontflip</description>
    <flip_label>frontflip</flip_label>

    <!-- rotation: axis 0=roll, 1=pitch, 2=yaw -->
    <angle_axis>1</angle_axis>
    <angle_total>6.283185307179586</angle_total>

    <!-- landing target offset -->
    <target_pos_axis>0</target_pos_axis>
    <target_delta>0</target_delta>

    <!-- phase durations (seconds) -->
    <pre_flip_t>1.0</pre_flip_t>
    <flight_t>0.4</flight_t>
    <land_t>1.0</land_t>

    <!-- solver -->
    <dt>0.02</dt>
    <max_iter>200</max_iter>
    <tol>1e-3</tol>

    <!-- output -->
    <output>export/go2_frontflip.csv</output>
    <solution_name>frontflip</solution_name>
    <vis>true</vis>

    <!-- costs (0 = disabled) -->
    <!-- <w_base_pose>1e-1</w_base_pose>
    <w_base_height>1e-1</w_base_height> -->
</go2_flip>
